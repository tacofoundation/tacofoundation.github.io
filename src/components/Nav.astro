---
import { navItems } from "../config/nav.js";
---

<nav class="bg-[#13151a]">
  <div class="max-w-screen-xl flex flex-wrap items-center justify-between mx-auto p-4" x-data="{ open: false }">
    <!-- Logo y nombre -->
    <a href="/" class="flex items-center space-x-3 rtl:space-x-reverse">
      <img src="/taco.png" class="h-8" alt="Taco logo" />
      <span class="self-center text-2xl font-semibold whitespace-nowrap text-white">TACO Foundation</span>
    </a>

    <!-- Menú hamburguesa y búsqueda para dispositivos pequeños -->
    <div class="flex md:order-2">
      <!-- Icono de GitHub para dispositivos pequeños (antes del menú hamburguesa) -->
      <a
        href="https://github.com/tacofoundation/tortilla-python"
        class="text-white hover:text-yellow-500 transition duration-300 mr-2 block md:hidden"
        aria-label="GitHub"
      >
        <i class="fab fa-github text-3xl"></i>
      </a>

      <!-- Botón hamburguesa para dispositivos pequeños -->
      <button
        type="button"
        @click="open = !open"
        class="inline-flex items-center p-2 w-10 h-10 justify-center text-sm text-gray-500 rounded-lg md:hidden hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-gray-200 dark:text-gray-400 dark:hover:bg-gray-700 dark:focus:ring-gray-600"
        aria-controls="navbar-search"
        aria-expanded="false"
      >
        <span class="sr-only">Open main menu</span>
        <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 14">
          <path
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M1 1h15M1 7h15M1 13h15"
          ></path>
        </svg>
      </button>

      <!-- Input de búsqueda para pantallas medianas y grandes (fuera del menú) -->
      <div class="relative hidden md:block">
        <div class="absolute inset-y-0 start-0 flex items-center ps-3 pointer-events-none">
          <svg class="w-4 h-4 text-gray-500 dark:text-gray-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 20 20">
            <path
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="m19 19-4-4m0-7A7 7 0 1 1 1 8a7 7 0 0 1 14 0Z"
            ></path>
          </svg>
        </div>
        <input
          type="text"
          id="search-navbar"
          class="block w-full p-2 ps-10 text-sm text-gray-900 border border-gray-300 rounded-lg bg-gray-50 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500"
          placeholder="Search..."
        />
      </div>
    </div>

    <!-- Menú de navegación y búsqueda (visible solo cuando open es true en dispositivos pequeños) -->
    <div
      class="w-full md:flex md:items-center md:w-auto md:order-1"
      id="navbar-search"
      :class="{ 'block': open, 'hidden': !open }"
    >
      <!-- Input de búsqueda para pantallas pequeñas -->
      <div class="relative my-4 md:hidden">
        <div class="absolute inset-y-0 start-0 flex items-center ps-3 pointer-events-none">
          <svg class="w-4 h-4 text-gray-500 dark:text-gray-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 20 20">
            <path
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="m19 19-4-4m0-7A7 7 0 1 1 1 8a7 7 0 0 1 14 0Z"
            ></path>
          </svg>
        </div>
        <input
          type="text"
          id="search-navbar"
          class="block w-full p-2 ps-10 text-sm text-gray-900 border border-gray-300 rounded-lg bg-gray-50 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500"
          placeholder="Search..."
        />
      </div>

      <!-- Opciones de navegación con text-lg y hover en amarillo -->
      <ul class="flex flex-col p-4 md:p-0 mt-4 font-medium border border-gray-700 rounded-lg bg-[#13151a] md:space-x-8 rtl:space-x-reverse md:flex-row md:mt-0 md:border-0 md:bg-[#13151a] dark:bg-[#13151a] text-lg">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="block py-2 px-2 text-white hover:text-yellow-500 md:hover:bg-transparent dark:hover:bg-gray-700 dark:hover:text-white"
            >
              {item.name}
            </a>
          </li>
        ))}
      </ul>

      <!-- Icono de GitHub para pantallas grandes (después del menú de navegación) -->
      <a
        href="https://github.com/tacofoundation/tortilla-python"
        class="text-white hover:text-yellow-500 transition duration-300 ml-11 hidden md:block"
        aria-label="GitHub"
      >
        <i class="fab fa-github text-3xl"></i>
      </a>
    </div>
  </div>
</nav>
